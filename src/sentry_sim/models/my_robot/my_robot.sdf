<?xml version="1.0" ?>
<sdf version="1.9">
    <model name="my_robot">
        <!-- 底盘 -->
        <link name="chassis">
            <pose>0 0 0.05 0 0 0</pose>
            <inertial>
                <mass>5.0</mass>
                <inertia>
                    <ixx>0.083</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.083</iyy>
                    <iyz>0</iyz>
                    <izz>0.083</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <box>
                        <size>0.4 0.3 0.1</size>
                    </box>
                </geometry>
            </collision>
            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.4 0.3 0.1</size>
                    </box>
                </geometry>
                <material>
                    <diffuse>1 0 0 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 云台底座 -->
        <link name="turret_base">
            <pose>0 0 0.12 0 0 0</pose>
            <inertial>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.01</iyy>
                    <iyz>0</iyz>
                    <izz>0.01</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.04</length>
                    </cylinder>
                </geometry>
            </collision>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.04</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0.5 0.5 0.5 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 云台炮塔 -->
        <link name="turret">
            <pose>0 0 0.18 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.005</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.005</iyy>
                    <iyz>0</iyz>
                    <izz>0.005</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <box>
                        <size>0.12 0.08 0.06</size>
                    </box>
                </geometry>
            </collision>
            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.12 0.08 0.06</size>
                    </box>
                </geometry>
                <material>
                    <diffuse>0.3 0.3 0.3 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 炮管 -->
        <link name="barrel">
            <pose>0.1 0 0.18 0 0 0</pose>
            <inertial>
                <mass>0.2</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.001</iyy>
                    <iyz>0</iyz>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.01</radius>
                        <length>0.15</length>
                    </cylinder>
                </geometry>
            </collision>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.01</radius>
                        <length>0.15</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0.2 0.2 0.2 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 前左轮 -->
        <link name="front_left_wheel">
            <pose>0.15 0.2 0 1.5707 0 0</pose>
            <inertial>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.001</iyy>
                    <iyz>0</iyz>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.8</mu>
                            <mu2>0.8</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0 1 0 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 前右轮 -->
        <link name="front_right_wheel">
            <pose>0.15 -0.2 0 1.5707 0 0</pose>
            <inertial>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.001</iyy>
                    <iyz>0</iyz>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.8</mu>
                            <mu2>0.8</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0 1 0 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 后左轮 -->
        <link name="back_left_wheel">
            <pose>-0.15 0.2 0 1.5707 0 0</pose>
            <inertial>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.001</iyy>
                    <iyz>0</iyz>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.8</mu>
                            <mu2>0.8</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0 1 0 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 后右轮 -->
        <link name="back_right_wheel">
            <pose>-0.15 -0.2 0 1.5707 0 0</pose>
            <inertial>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.001</iyy>
                    <iyz>0</iyz>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.8</mu>
                            <mu2>0.8</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.08</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0 1 0 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- 激光雷达 -->
        <link name="lidar">
            <pose>0 0 0.25 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyy>0.001</iyy>
                    <iyz>0</iyz>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.03</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <diffuse>0 0 1 1</diffuse>
                </material>
            </visual>
            <sensor name="lidar_sensor" type="lidar">
                <pose>0 0 0 0 0 0</pose>
                <always_on>true</always_on>
                <update_rate>10</update_rate>
                <ray>
                    <scan>
                        <horizontal>
                            <samples>360</samples>
                            <resolution>1</resolution>
                            <min_angle>-3.14159</min_angle>
                            <max_angle>3.14159</max_angle>
                        </horizontal>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>10.0</max>
                        <resolution>0.01</resolution>
                    </range>
                </ray>
                <topic>/lidar</topic>
            </sensor>
        </link>

        <!-- 关节 -->
        <!-- 轮子关节 -->
        <joint name="front_left_wheel_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_left_wheel</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                    <effort>1e6</effort>
                    <velocity>100</velocity>
                </limit>
            </axis>
        </joint>

        <joint name="front_right_wheel_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_right_wheel</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                    <effort>1e6</effort>
                    <velocity>100</velocity>
                </limit>
            </axis>
        </joint>

        <joint name="back_left_wheel_joint" type="revolute">
            <parent>chassis</parent>
            <child>back_left_wheel</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                    <effort>1e6</effort>
                    <velocity>100</velocity>
                </limit>
            </axis>
        </joint>

        <joint name="back_right_wheel_joint" type="revolute">
            <parent>chassis</parent>
            <child>back_right_wheel</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                    <effort>1e6</effort>
                    <velocity>100</velocity>
                </limit>
            </axis>
        </joint>

        <!-- 云台关节 -->
        <joint name="turret_base_joint" type="fixed">
            <parent>chassis</parent>
            <child>turret_base</child>
        </joint>

        <joint name="turret_joint" type="revolute">
            <parent>turret_base</parent>
            <child>turret</child>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <lower>-3.14159</lower>
                    <upper>3.14159</upper>
                    <effort>1e6</effort>
                    <velocity>10</velocity>
                </limit>
            </axis>
        </joint>

        <joint name="barrel_joint" type="revolute">
            <parent>turret</parent>
            <child>barrel</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>-0.5</lower>
                    <upper>0.5</upper>
                    <effort>1e6</effort>
                    <velocity>5</velocity>
                </limit>
            </axis>
        </joint>

        <joint name="lidar_joint" type="fixed">
            <parent>turret</parent>
            <child>lidar</child>
        </joint>

        <!-- 四个独立轮子速度控制器 -->
        <plugin name="gz::sim::systems::JointController" filename="libgz-sim-joint-controller-system.so">
            <joint_name>front_left_wheel_joint</joint_name>
            <topic>/front_left_wheel/cmd_vel</topic>
            <p_gain>10</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>0.01</d_gain>
        </plugin>

        <plugin name="gz::sim::systems::JointController" filename="libgz-sim-joint-controller-system.so">
            <joint_name>front_right_wheel_joint</joint_name>
            <topic>/front_right_wheel/cmd_vel</topic>
            <p_gain>10</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>0.01</d_gain>
        </plugin>

        <plugin name="gz::sim::systems::JointController" filename="libgz-sim-joint-controller-system.so">
            <joint_name>back_left_wheel_joint</joint_name>
            <topic>/back_left_wheel/cmd_vel</topic>
            <p_gain>10</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>0.01</d_gain>
        </plugin>

        <plugin name="gz::sim::systems::JointController" filename="libgz-sim-joint-controller-system.so">
            <joint_name>back_right_wheel_joint</joint_name>
            <topic>/back_right_wheel/cmd_vel</topic>
            <p_gain>10</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>0.01</d_gain>
        </plugin>

        <!-- 云台位置控制器 -->
        <plugin name="gz::sim::systems::JointPositionController" filename="libgz-sim-joint-position-controller-system.so">
            <joint_name>turret_joint</joint_name>
            <topic>/turret/cmd_pos</topic>
            <p_gain>100</p_gain>
            <i_gain>10</i_gain>
            <d_gain>1</d_gain>
        </plugin>

        <plugin name="gz::sim::systems::JointPositionController" filename="libgz-sim-joint-position-controller-system.so">
            <joint_name>barrel_joint</joint_name>
            <topic>/barrel/cmd_pos</topic>
            <p_gain>100</p_gain>
            <i_gain>10</i_gain>
            <d_gain>1</d_gain>
        </plugin>
    </model>
</sdf>